# 1-qadam: Python bazaviy obrazini tanlash
FROM python:3.11-slim

# 2-qadam: Muhit o'zgaruvchilari (Python xatolarini tez ko'rsatishi uchun)
ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1

# 3-qadam: Ishchi katalogni yaratish
WORKDIR /app

# 4-qadam: Tizim kutubxonalarini o'rnatish (PostgreSQL va boshqalar uchun)
RUN apt-get update && apt-get install -y \
    build-essential \
    libpq-dev \
    --no-install-recommends && \
    rm -rf /var/lib/apt/lists/*

# 5-qadam: Bog'liqliklarni o'rnatish
COPY requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

# 6-qadam: Loyiha fayllarini nusxalash
COPY . /app/

# 7-qadam: Statik fayllarni yig'ish (Settingsdagi WhiteNoise uchun)
# Bu qadamda SECRET_KEY bo'lishi shart, agar muhitda bo'lmasa vaqtinchalik dummy key beramiz
RUN python manage.py collectstatic --noinput

# 8-qadam: Portni ochish (Render odatda 10000 yoki 8000 ishlatadi)
EXPOSE 8000

# 9-qadam: Serverni ishga tushirish (Gunicorn tavsiya etiladi)
CMD ["gunicorn", "school_project.wsgi:application", "--bind", "0.0.0.0:8000"]