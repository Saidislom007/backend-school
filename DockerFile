FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1
ENV PORT 8080

WORKDIR /app

RUN apt-get update && apt-get install -y \
    build-essential \
    libpq-dev \
    --no-install-recommends && \
    rm -rf /var/lib/apt/lists/*

COPY requirements.txt /app/
RUN pip install --no-cache-dir -r requirements.txt

COPY . /app/

# MANA SHU QATOR STATIK FAYLLARNI DOIMIY QILADI
RUN DJANGO_SECRET_KEY=dummy_key python manage.py collectstatic --noinput

CMD python manage.py migrate && gunicorn school_project.wsgi:application --bind 0.0.0.0:${PORT}